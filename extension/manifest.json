{
  "manifest_version": 3,
  "name": "淘宝评论助手",
  "version": "2.9.8",
  "description": "帮助提取淘宝/天猫商品评论数据 - 侧边栏版",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "author": "Product Review Analysis Team",
  "homepage_url": "https://github.com/yourusername/ProductReviewAnalysis",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.taobao.com/*",
    "https://*.tmall.com/*",
    "https://*.tmall.hk/*",
    "https://*.world.tmall.com/*",
    "https://*.import.tmall.com/*",
    "https://detail.tmall.com/*",
    "https://detail.tmall.hk/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "淘宝评论助手 - 点击打开侧边栏"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.taobao.com/*",
        "https://*.tmall.com/*",
        "https://*.tmall.hk/*",
        "https://*.world.tmall.com/*",
        "https://*.import.tmall.com/*",
        "https://detail.tmall.com/*",
        "https://detail.tmall.hk/*"
      ],
      "js": ["config.js", "content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["*.js", "*.css"],
      "matches": [
        "https://*.taobao.com/*",
        "https://*.tmall.com/*",
        "https://*.tmall.hk/*",
        "https://*.world.tmall.com/*",
        "https://*.import.tmall.com/*",
        "https://detail.tmall.com/*",
        "https://detail.tmall.hk/*"
      ]
    }
  ]
}
