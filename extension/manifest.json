{
  "manifest_version": 3,
  "name": "淘宝评论助手",
  "version": "2.8.2",
  "description": "帮助提取淘宝/天猫商品评论数据 - 独立封装版本",
  "author": "Product Review Analysis Team",
  "homepage_url": "https://github.com/yourusername/ProductReviewAnalysis",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.taobao.com/*",
    "https://*.tmall.com/*",
    "https://*.tmall.hk/*",
    "https://*.world.tmall.com/*",
    "https://*.import.tmall.com/*",
    "https://detail.tmall.com/*",
    "https://detail.tmall.hk/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "淘宝评论助手"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.taobao.com/*",
        "https://*.tmall.com/*",
        "https://*.tmall.hk/*",
        "https://*.world.tmall.com/*",
        "https://*.import.tmall.com/*",
        "https://detail.tmall.com/*",
        "https://detail.tmall.hk/*"
      ],
      "js": ["config.js", "content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["*.js", "*.css"],
      "matches": [
        "https://*.taobao.com/*",
        "https://*.tmall.com/*",
        "https://*.tmall.hk/*",
        "https://*.world.tmall.com/*",
        "https://*.import.tmall.com/*",
        "https://detail.tmall.com/*",
        "https://detail.tmall.hk/*"
      ]
    }
  ]
}
