{
  "manifest_version": 3,
  "name": "淘宝评论助手",
  "version": "1.0.2",
  "description": "帮助提取淘宝/天猫商品评论数据",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.taobao.com/*",
    "https://*.tmall.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "淘宝评论助手"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.taobao.com/*",
        "https://*.tmall.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
